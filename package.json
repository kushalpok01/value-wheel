        "@nestjs/testing": "^7.6.15",
        "@types/express": "^4.17.21",
        "@types/jest": "^28.1.8",
        "@types/node": "^20.14.9",
        "@types/supertest": "^2.0.16",
        "jest": "^28.1.3",
        "patch-package": "^8.0.1",
        "prettier": "^3.4.2",
        "source-map-support": "^0.5.21",
        "supertest": "^6.3.4",
        "ts-jest": "^28.0.8",
        "ts-loader": "^9.5.2",
