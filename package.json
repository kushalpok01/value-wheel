        "class-validator": "^0.15.1",
        "cookie-session": "^2.1.1",
        "cross-env": "^10.1.0",
        "reflect-metadata": "^0.1.13",
        "rxjs": "^6.6.7",
        "sqlite3": "^5.1.7",
        "typeorm": "^0.2.41"
